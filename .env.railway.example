# Railway environment variables for api.crowelogic.com (control plane).
# Copy values into Railway via `railway variables set KEY=value` or the UI.
# DO NOT commit real values. Every var ending in _KEY, _SECRET, or _URL may be sensitive.

# --- Database (Neon) -----------------------------------------------------
# Railway's Postgres plugin will set DATABASE_URL automatically if attached.
# If using external Neon instead, paste the connection string here.
# CONTROL_PLANE_DATABASE_URL=postgresql://...neon.tech/neondb?sslmode=require
# NEON_DATABASE_URL=postgresql://...neon.tech/neondb?sslmode=require

# --- Auth ----------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
CROWE_JWT_SECRET=REPLACE_ME_WITH_64_RANDOM_BYTES

# --- Stripe (populated by scripts/stripe_bootstrap.py) -------------------
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Launch plan price IDs (personal/pro/team/enterprise vocabulary, migration 007).
# control_plane.plans.stripe_price_id() resolves these first and falls back to
# the legacy STRIPE_PRICE_DEVELOPER/STUDIO/LAB envs below if unset, so a partial
# rollout works during cutover.
STRIPE_PRICE_PERSONAL=price_REPLACE_ME
STRIPE_PRICE_PERSONAL_ANNUAL=price_REPLACE_ME
STRIPE_PRICE_PRO=price_REPLACE_ME
STRIPE_PRICE_PRO_ANNUAL=price_REPLACE_ME
STRIPE_PRICE_TEAM=price_REPLACE_ME
STRIPE_PRICE_TEAM_ANNUAL=price_REPLACE_ME
STRIPE_PRICE_ENTERPRISE=price_REPLACE_ME
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_REPLACE_ME
# BYOK is hidden from public pricing; only set if you're selling it.
STRIPE_PRICE_BYOK=
STRIPE_PRICE_BYOK_ANNUAL=

# Legacy plan price IDs (developer/studio/lab). Kept for fallback during the
# cutover. Safe to remove once all environments have the launch vars set and
# migration 007 has been applied.
STRIPE_PRICE_DEVELOPER=price_REPLACE_ME
STRIPE_PRICE_DEVELOPER_ANNUAL=price_REPLACE_ME
STRIPE_PRICE_STUDIO=price_REPLACE_ME
STRIPE_PRICE_STUDIO_ANNUAL=price_REPLACE_ME
STRIPE_PRICE_LAB=price_REPLACE_ME
STRIPE_PRICE_LAB_ANNUAL=price_REPLACE_ME
STRIPE_PRICE_USAGE_TOKENS=price_REPLACE_ME

STRIPE_SUCCESS_URL=https://api.crowelogic.com/billing/success
STRIPE_CANCEL_URL=https://api.crowelogic.com/billing/cancel
STRIPE_PORTAL_RETURN_URL=https://api.crowelogic.com/account

# --- Model providers (only what control plane calls) ---------------------
# Add the ones you actually route traffic through. Others can be loaded lazily.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_AI_FOUNDRY_KEY=
AZURE_AI_FOUNDRY_ENDPOINT=
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
FIREWORKS_API_KEY=
MISTRAL_API_KEY=

# --- Runtime ------------------------------------------------------------
# Railway injects PORT; we honour it. No need to set unless overriding locally.
# PORT=8001

# Migrations to skip (001 is legacy SQLite-dialect, lives alongside 002+ Postgres).
CONTROL_PLANE_MIGRATION_SKIP=001_initial.sql
