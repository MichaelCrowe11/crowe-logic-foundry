FROM python:3.12-slim

LABEL maintainer="michael@crowelogic.com"
LABEL org.opencontainers.image.title="Talon Studio"
LABEL org.opencontainers.image.description="Crowe Logic Foundry with Talon Composer and Substrate Studio dashboards"
LABEL org.opencontainers.image.vendor="Crowe Logic, Inc."

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl build-essential nodejs npm \
    && rm -rf /var/lib/apt/lists/*

# Python deps
COPY requirements.txt requirements-control-plane.txt ./
RUN pip install --no-cache-dir -r requirements.txt \
    && pip install --no-cache-dir -r requirements-control-plane.txt

# Install crowe-logic package
COPY . .
RUN pip install --no-cache-dir -e .

ENV PYTHONPATH=/app \
    PYTHONUNBUFFERED=1

# Bridge default; Fly overrides CROWE_BRIDGE_PORT to 8080 via fly.studio.toml
ENV CROWE_BRIDGE_PORT=8011

EXPOSE 8011

CMD ["python", "-m", "cli.openai_bridge"]
