# Copy to .env and adjust for your deployment target.
#
# The LiteLLM router exposes the single OpenAI-compatible endpoint that
# CroweLM points to:
#   CROWE_OPEN_ENDPOINT=http://<router-host>:4000/v1
#
# Optional auth in front of the router:
CROWE_OPEN_PROXY_MASTER_KEY=

# Router listen port
CROWE_OPEN_PORT=4000

# External/local storage roots for model weights and optional Ollama dev cache.
# On this Mac, the external volume is mounted at /Volumes/Elements.
CROWE_OPEN_MODEL_CACHE_DIR=/Volumes/Elements/crowe-open-inference/models
CROWE_OPEN_OLLAMA_DIR=/Volumes/Elements/crowe-open-inference/ollama

# Hugging Face token for gated/open-weight pulls
HF_TOKEN=

# Upstream OpenAI-compatible workers.
# These can point at the optional local compose services below, or at
# dedicated external GPU hosts running vLLM/SGLang/NIM.
CROWE_GLM51_API_BASE=http://glm51:8000/v1
CROWE_GLM51_API_KEY=

CROWE_GLM5_API_BASE=http://glm51:8000/v1
CROWE_GLM5_API_KEY=

CROWE_QWEN35_API_BASE=http://qwen35:8000/v1
CROWE_QWEN35_API_KEY=

CROWE_DEEPSEEK_R1_API_BASE=http://deepseek-r1:8000/v1
CROWE_DEEPSEEK_R1_API_KEY=

CROWE_DEEPSEEK_V3_API_BASE=http://deepseek-v3:8000/v1
CROWE_DEEPSEEK_V3_API_KEY=

CROWE_KIMI_K25_API_BASE=http://kimi-k25:8000/v1
CROWE_KIMI_K25_API_KEY=

CROWE_KIMI_K2_THINKING_API_BASE=http://kimi-k2-thinking:8000/v1
CROWE_KIMI_K2_THINKING_API_KEY=

CROWE_MISTRAL_LARGE_API_BASE=http://mistral-large:8000/v1
CROWE_MISTRAL_LARGE_API_KEY=

CROWE_LLAMA4_MAVERICK_API_BASE=http://llama4-maverick:8000/v1
CROWE_LLAMA4_MAVERICK_API_KEY=

CROWE_GEMMA4_API_BASE=http://gemma4:8000/v1
CROWE_GEMMA4_API_KEY=

# Local worker tuning
VLLM_IMAGE=vllm/vllm-openai:latest
VLLM_GPU_MEMORY_UTILIZATION=0.92
VLLM_MAX_MODEL_LEN=32768
VLLM_DTYPE=bfloat16
VLLM_DOWNLOAD_DIR=/models

# Per-model served names (must stay aligned with backend_name mappings)
GLM51_SERVED_MODEL_NAME=z-ai/glm5.1
GLM5_SERVED_MODEL_NAME=z-ai/glm5
QWEN35_SERVED_MODEL_NAME=qwen/qwen3.5-397b-a17b
DEEPSEEK_R1_SERVED_MODEL_NAME=deepseek-ai/deepseek-r1
DEEPSEEK_V3_SERVED_MODEL_NAME=deepseek-ai/deepseek-v3.2
KIMI_K25_SERVED_MODEL_NAME=moonshotai/kimi-k2.5
KIMI_K2_THINKING_SERVED_MODEL_NAME=moonshotai/kimi-k2-thinking
MISTRAL_LARGE_SERVED_MODEL_NAME=mistralai/mistral-large-3-675b-instruct-2512
LLAMA4_MAVERICK_SERVED_MODEL_NAME=meta/llama-4-maverick-17b-128e-instruct
GEMMA4_SERVED_MODEL_NAME=google/gemma-4-27b-it

# Local worker model ids
GLM51_MODEL_ID=THUDM/GLM-5.1
GLM5_MODEL_ID=z-ai/glm5
QWEN35_MODEL_ID=Qwen/Qwen3.5-32B-Instruct
DEEPSEEK_R1_MODEL_ID=deepseek-ai/DeepSeek-R1
DEEPSEEK_V3_MODEL_ID=deepseek-ai/DeepSeek-V3.2
KIMI_K25_MODEL_ID=moonshotai/Kimi-K2.5
KIMI_K2_THINKING_MODEL_ID=moonshotai/Kimi-K2-Thinking
MISTRAL_LARGE_MODEL_ID=mistralai/Mistral-Large-Instruct-2411
LLAMA4_MAVERICK_MODEL_ID=meta-llama/Llama-4-Maverick-17B-128E-Instruct
GEMMA4_MODEL_ID=google/gemma-4-27b-it

# Tensor parallel defaults for local worker profiles.
GLM51_TENSOR_PARALLEL_SIZE=4
GLM5_TENSOR_PARALLEL_SIZE=4
QWEN35_TENSOR_PARALLEL_SIZE=2
DEEPSEEK_R1_TENSOR_PARALLEL_SIZE=4
DEEPSEEK_V3_TENSOR_PARALLEL_SIZE=4
KIMI_K25_TENSOR_PARALLEL_SIZE=2
KIMI_K2_THINKING_TENSOR_PARALLEL_SIZE=2
MISTRAL_LARGE_TENSOR_PARALLEL_SIZE=2
LLAMA4_MAVERICK_TENSOR_PARALLEL_SIZE=2
GEMMA4_TENSOR_PARALLEL_SIZE=1
