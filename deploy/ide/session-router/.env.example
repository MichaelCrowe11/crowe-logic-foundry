# deploy/ide/session-router/.env.example
#
# IDE_JWT_SECRET — shared HS256 secret used to sign and verify both the
# handoff JWT (issued by the launcher in crowe-logic-ai) and the long-lived
# session JWT (minted by this router after a successful handoff).
#
# Generate with: openssl rand -hex 32
# This MUST be byte-identical to the IDE_JWT_SECRET set in the Railway env
# vars for the crowe-logic-ai service. Drift causes every handoff to 401.
IDE_JWT_SECRET=

# Port for the Session Router to listen on
PORT=3001

# Docker image name for code-server containers
IMAGE_NAME=crowe-ide-codeserver

# Cookie domain — leave empty for host-only (default). Set to your IDE host
# for explicit control, e.g., COOKIE_DOMAIN=ide.southwestmushrooms.com
COOKIE_DOMAIN=

# Idle timeout settings
# NOTE: lastActivity is currently derived from container creation time, not
# real activity. Set IDLE_STOP_MINUTES generously to avoid killing active
# sessions. 240 minutes (4 hours) is a safer default than 30.
IDLE_STOP_MINUTES=240
IDLE_REMOVE_HOURS=24
IDLE_CHECK_INTERVAL_MINUTES=5

# Control Plane connection (for entitlement checks + metering).
# Leave empty for development mode (fail-open, no entitlement enforcement).
CONTROL_PLANE_URL=
CONTROL_PLANE_API_KEY=
