# deploy/ide/.env.full.example
#
# Environment variables for docker-compose.full.yml.
# Copy to .env and fill in values before running:
#   cp .env.full.example .env
#   docker compose -f docker-compose.full.yml up -d

# ── Required ────────────────────────────────────────────────────────
# Shared JWT secret — MUST match the value in Railway's crowe-logic-ai service.
# Generate with: openssl rand -hex 32
IDE_JWT_SECRET=

# Postgres password (only needed if using local-db profile)
POSTGRES_PASSWORD=

# ── Control Plane ───────────────────────────────────────────────────
# Database URL. For Neon (production):
#   CONTROL_PLANE_DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/crowe_foundry?sslmode=require
# For local Postgres (local-db profile), leave empty to use auto-composed URL.
CONTROL_PLANE_DATABASE_URL=

# Internal API key for session-router → control-plane communication.
# Generate with: openssl rand -hex 32
CONTROL_PLANE_API_KEY=

# ── Stripe Billing ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_DEVELOPER=
STRIPE_PRICE_STUDIO=
STRIPE_PRICE_LAB=
STRIPE_PRICE_ENTERPRISE=

# ── AI Provider Keys ───────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=

# ── Session Router ──────────────────────────────────────────────────
COOKIE_DOMAIN=ide.southwestmushrooms.com
IDLE_STOP_MINUTES=240
IDLE_REMOVE_HOURS=24
IDLE_CHECK_INTERVAL_MINUTES=5

# ── Admin ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@southwestmushrooms.com

# ── Postgres (local-db profile only) ───────────────────────────────
POSTGRES_USER=crowe
POSTGRES_DB=crowe_foundry
