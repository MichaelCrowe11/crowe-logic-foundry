# Crowe Logic Foundry
# Copy to .env and fill in your values:  cp .env.example .env

# Legacy Azure AI Agents project endpoint (only used if the model chain falls
# back to the legacy `provider="azure"` path).
PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
MODEL_DEPLOYMENT_NAME=gpt-oss-120b

# Azure AI Foundry / OpenAI-compatible deployments
# Examples: https://your-resource.openai.azure.com/openai/v1/
# Managed premium fallback resource (for Apex Premium and related escalations)
AZURE_CORE_ENDPOINT=
AZURE_CORE_API_KEY=

# Crowe Logic-managed open-model cluster (preferred primary backend).
# Point this at your self-hosted vLLM / SGLang / NIM-compatible `/v1` surface.
# API key is optional for trusted internal clusters; leave blank if not required.
# Example local router: http://localhost:4000/v1
CROWE_OPEN_ENDPOINT=
CROWE_OPEN_API_KEY=

# Dedicated Azure resource for CroweLM Titan Premium (gpt-5.4)
AZURE_8909_ENDPOINT=
AZURE_8909_API_KEY=

# Dedicated Azure resource for CroweLM Oracle (grok-4-20-reasoning)
AZURE_4291_ENDPOINT=
AZURE_4291_API_KEY=

# Dedicated Azure resource for CroweLM Reason, Vector, and Forge
# Typical deployments: DeepSeek-R1, DeepSeek-V3-1, Llama-3-3-70B
AZURE_7858_ENDPOINT=
AZURE_7858_API_KEY=

# Dedicated Azure resource for CroweLM Edge and Atlas
# Typical deployments: Mistral-Large-3, FW-MiniMax-M2.5
AZURE_9536_ENDPOINT=
AZURE_9536_API_KEY=

# Optional dedicated CroweLM Motion deployment for video generation.
# Accepts either an OpenAI endpoint (https://...openai.azure.com/openai/v1/)
# or a Foundry services endpoint (https://...services.ai.azure.com).
# If left empty, sora_generate_video falls back to AZURE_CORE_ENDPOINT/API_KEY.
AZURE_SORA_ENDPOINT=
AZURE_SORA_API_KEY=
AZURE_SORA_DEPLOYMENT_NAME=sora-2

# Z.AI OpenAI-compatible surface for CroweLM Dense / the Crowe general LM variant.
# The API path is versioned already, so keep the `/api/paas/v4` suffix.
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_API_KEY=

# Optional legacy Azure GLM endpoint retained for older Dense scripts / backfills.
# Typical deployment: FW-GLM-5
AZURE_GLM_ENDPOINT=
AZURE_GLM_API_KEY=

# Azure ML Managed Online Endpoint for CroweLM Dense (GLM 5.1).
# Created by: python scripts/deploy_glm51.py
# Store the OpenAI-compatible base URL, including /v1.
# Example: https://<endpoint-name>.<region>.inference.ml.azure.com/v1
AZURE_GLM51_ENDPOINT=
AZURE_GLM51_API_KEY=

# Azure ML workspace details (for deploy_glm51.py and fine-tuning scripts).
# AZURE_ML_SUBSCRIPTION_ID defaults to AZURE_SUBSCRIPTION_ID if not set.
# AZURE_ML_RESOURCE_GROUP defaults to AZURE_RESOURCE_GROUP if not set.
AZURE_ML_WORKSPACE_NAME=

# Azure-hosted Anthropic surface for CroweLM Prime
# Example: https://your-resource.openai.azure.com/anthropic
# Typical deployment on the anthropic surface: claude-opus-4-6
AZURE_ANTHROPIC_ENDPOINT=
AZURE_ANTHROPIC_API_KEY=

# Azure-hosted Anthropic surface for CroweLM Sovereign and Classic
# Typical deployments: claude-opus-4-6-2, claude-opus-4-5
AZURE_1960_ANTHROPIC_ENDPOINT=
AZURE_1960_API_KEY=

# NVIDIA NIM / DGX Cloud
NVIDIA_NIM_ENDPOINT=
NVIDIA_API_KEY=

# NVIDIA NemoClaw (Brev-hosted VM: NIM inference + OpenShell sandbox on one host).
# Powers the `crowelm-talon-nemoclaw` model entry and the nemoclaw_shell tool.
# Run scripts/nemoclaw_recon.sh on the VM to discover the exact endpoints and
# paths; it prints a ready-to-paste block that fills the rest of these.
NEMOCLAW_ENDPOINT=
NEMOCLAW_API_KEY=
# Optional: override the sandbox base if OpenShell runs on a different URL than
# NIM inference. Defaults to NEMOCLAW_ENDPOINT.
NEMOCLAW_SANDBOX_URL=
# Optional: override the OpenShell HTTP paths if this NemoClaw build serves
# them elsewhere. Defaults below match the documented Agent Toolkit surface.
NEMOCLAW_SANDBOX_EXEC_PATH=/openshell/v1/exec
NEMOCLAW_SANDBOX_HEALTH_PATH=/openshell/v1/health
# Optional: HTTP-level timeout floor in seconds for sandbox requests.
NEMOCLAW_SANDBOX_TIMEOUT=180

# Optional local / fallback providers
OLLAMA_BASE_URL=http://localhost:11434/v1
OPENROUTER_API_KEY=

# Bing Search connection ID (optional — for web grounding)
AZURE_BING_CONNECTION_ID=

# Azure AI Search connection ID (optional — for vector search / RAG)
AI_AZURE_AI_CONNECTION_ID=

# Azure AI Search index name
AI_SEARCH_INDEX_NAME=crowe-logic-kb

# Azure subscription details
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=

# Optional: Application Insights connection string for tracing
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Crowe Logic Platform (ai.southwestmushrooms.com)
CROWE_LOGIC_URL=https://ai.southwestmushrooms.com
CROWE_LOGIC_KEY=

# CroweLM Agent Pipeline
CROWELM_STAGING_DIR=data/crowelm-unified/staging
CROWELM_AUTO_APPROVE_THRESHOLD=0.85
CROWELM_REVIEW_THRESHOLD=0.5

# Anonymous free tier (control plane; see docs/superpowers/specs/2026-06-05-first-run-onboarding-design.md)
# Signing secret for crowe_anon_ device tokens. Generate: openssl rand -hex 32
# Register endpoint 500s without it; token verification fails closed.
CROWE_ANON_SIGNING_SECRET=
# CroweLM Mycelium backend (Modal app crowe-mycelium-serve, Ollama OpenAI-compat)
# serving anonymous turns. Auth is Modal PROXY-AUTH headers (mint a token at the
# Modal dashboard -> Settings -> Proxy Auth Tokens), not a bearer key.
CROWELM_MYCELIUM_ENDPOINT=https://michaelcrowe11--crowe-mycelium-serve-serve.modal.run
CROWELM_MYCELIUM_MODAL_KEY=
CROWELM_MYCELIUM_MODAL_SECRET=
