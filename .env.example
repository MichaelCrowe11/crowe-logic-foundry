# Crowe Logic Foundry
# Copy to .env and fill in your values:  cp .env.example .env

# Legacy Azure AI Agents project endpoint (only used if the model chain falls
# back to the legacy `provider="azure"` path).
PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
MODEL_DEPLOYMENT_NAME=gpt-oss-120b

# Azure AI Foundry / OpenAI-compatible deployments
# Examples: https://your-resource.openai.azure.com/openai/v1/
# Typical deployments on the core resource: gpt-5.4-pro, gpt-5.4-nano, Kimi-K2.5
AZURE_CORE_ENDPOINT=
AZURE_CORE_API_KEY=

# Optional dedicated CroweLM Motion deployment for video generation.
# Accepts either an OpenAI endpoint (https://...openai.azure.com/openai/v1/)
# or a Foundry services endpoint (https://...services.ai.azure.com).
# If left empty, sora_generate_video falls back to AZURE_CORE_ENDPOINT/API_KEY.
AZURE_SORA_ENDPOINT=
AZURE_SORA_API_KEY=
AZURE_SORA_DEPLOYMENT_NAME=sora-2

# Optional second Azure OpenAI-compatible resource for GLM or other deployments
# Typical deployment on the GLM resource: FW-GLM-5
AZURE_GLM_ENDPOINT=
AZURE_GLM_API_KEY=

# Azure-hosted Anthropic surface
# Example: https://your-resource.openai.azure.com/anthropic
# Typical deployment on the anthropic surface: claude-opus-4-6
AZURE_ANTHROPIC_ENDPOINT=
AZURE_ANTHROPIC_API_KEY=

# NVIDIA NIM / DGX Cloud
NVIDIA_NIM_ENDPOINT=
NVIDIA_API_KEY=

# Optional local / fallback providers
OLLAMA_BASE_URL=http://localhost:11434/v1
OPENROUTER_API_KEY=

# Bing Search connection ID (optional — for web grounding)
AZURE_BING_CONNECTION_ID=

# Azure AI Search connection ID (optional — for vector search / RAG)
AI_AZURE_AI_CONNECTION_ID=

# Azure AI Search index name
AI_SEARCH_INDEX_NAME=crowe-logic-kb

# Azure subscription details
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=

# Optional: Application Insights connection string for tracing
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Crowe Logic Platform (ai.southwestmushrooms.com)
CROWE_LOGIC_URL=https://ai.southwestmushrooms.com
CROWE_LOGIC_KEY=

# CroweLM Agent Pipeline
CROWELM_STAGING_DIR=data/crowelm-unified/staging
CROWELM_AUTO_APPROVE_THRESHOLD=0.85
CROWELM_REVIEW_THRESHOLD=0.5
