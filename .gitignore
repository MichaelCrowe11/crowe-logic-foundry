.npmrc

# Stripe bootstrap output (.env.railway.out, .env.railway.out.test, etc.)
*.out
*.out.*
.env.railway.out*

# Ad-hoc backup files left by registry edits (models.extra.json.bak3 etc.)
*.bak
*.bak[0-9]*

# Studio runtime data (camera captures, shoot manifests)
studio_data/

# Local Postgres dumps captured before destructive migrations
backups/

# Studio training corpus data (frames, videos, models, manifests — 5.9G).
# Source scripts under training/{shot_selector,youtube_corpus}/*.py are tracked.
training/youtube_corpus/sw-mushrooms/

# CroweLM LoRA training artifacts (jsonl + state). The scripts to (re)build
# them ARE committed; the data is local-only because it contains material
# extracted from proprietary SOPs.
data/training/

# Local env backups (may contain live keys) — never commit
.env*.bak*
.env.env.bak-*

# Local Claude Code tooling state (worktrees, session data)
.claude/
