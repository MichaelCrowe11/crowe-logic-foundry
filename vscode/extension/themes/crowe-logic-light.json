  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#a89a72", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#7a5f2c" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "#a07415" } },
    { "scope": ["constant.language", "constant.character"], "settings": { "foreground": "#a07415" } },
    { "scope": ["keyword", "storage", "storage.type"], "settings": { "foreground": "#9c8451", "fontStyle": "bold" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#2a2620", "fontStyle": "bold" } },
    { "scope": ["entity.name.class", "entity.name.type", "support.class", "support.type"], "settings": { "foreground": "#3d6376" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#2a2620" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#3a3528", "fontStyle": "italic" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#9c8451" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#3d6376" } },
    { "scope": ["punctuation"], "settings": { "foreground": "#7a6f50" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#9c8451", "fontStyle": "bold" } },
    { "scope": ["markup.bold"], "settings": { "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "fontStyle": "italic" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#2e8540" } },
    { "scope": ["markup.deleted"], "settings": { "foreground": "#c0392b" } },
    { "scope": ["invalid"], "settings": { "foreground": "#c0392b", "fontStyle": "italic underline" } }
  ]
}
