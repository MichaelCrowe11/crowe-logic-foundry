  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#5a5340", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#d8c089" } },
    { "scope": ["constant.numeric"], "settings": { "foreground": "#d4a645" } },
    { "scope": ["constant.language", "constant.character"], "settings": { "foreground": "#d4a645" } },
    { "scope": ["keyword", "storage", "storage.type"], "settings": { "foreground": "#bfa669" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#fff7df" } },
    { "scope": ["entity.name.class", "entity.name.type", "support.class", "support.type"], "settings": { "foreground": "#a8c0c0" } },
    { "scope": ["variable", "variable.other"], "settings": { "foreground": "#e8e2cf" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#cfc6a8", "fontStyle": "italic" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#bfa669" } },
    { "scope": ["entity.name.tag"], "settings": { "foreground": "#8fa4bf" } },
    { "scope": ["punctuation"], "settings": { "foreground": "#7a7158" } },
    { "scope": ["markup.heading"], "settings": { "foreground": "#bfa669", "fontStyle": "bold" } },
    { "scope": ["markup.bold"], "settings": { "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "fontStyle": "italic" } },
    { "scope": ["markup.inserted"], "settings": { "foreground": "#6fbf73" } },
    { "scope": ["markup.deleted"], "settings": { "foreground": "#bf6f6f" } },
    { "scope": ["invalid"], "settings": { "foreground": "#bf6f6f", "fontStyle": "italic underline" } }
  ]
}
