  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#6c6452"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#d4a645"
      }
    },
    {
      "name": "String escape",
      "scope": [
        "constant.character.escape",
        "string source"
      ],
      "settings": {
        "foreground": "#d8c089"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#9fb87a"
      }
    },
    {
      "name": "Constant lang",
      "scope": [
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#d8c089",
        "fontStyle": ""
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#c08fcf"
      }
    },
    {
      "name": "Storage type",
      "scope": [
        "storage.type",
        "storage.type.function"
      ],
      "settings": {
        "foreground": "#c08fcf",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#8fbfbf"
      }
    },
    {
      "name": "Class name",
      "scope": [
        "entity.name.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#d8c089"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "meta.function-call entity.name.function",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#82a0c0"
      }
    },
    {
      "name": "Function definition",
      "scope": [
        "entity.name.function",
        "meta.definition.function"
      ],
      "settings": {
        "foreground": "#82a0c0"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#cfc6a8"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#e8e2cf"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "variable.other.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#d8c089"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#9c8451"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#bfa669"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#8fa4bf"
      }
    },
    {
      "name": "Attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#c08fcf",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSON key",
      "scope": [
        "support.type.property-name",
        "meta.object-literal.key",
        "string.json"
      ],
      "settings": {
        "foreground": "#c08fcf"
      }
    },
    {
      "name": "Heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#bfa669",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#d8c089",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#a89a72",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#8fa4bf",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#6c6452",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Diff added",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#6fbf73"
      }
    },
    {
      "name": "Diff removed",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#bf6f6f"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#bfa669"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#bf6f6f"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": {
      "foreground": "#8fbfbf"
    },
    "class": {
      "foreground": "#d8c089"
    },
    "interface": {
      "foreground": "#8fbfbf"
    },
    "type": {
      "foreground": "#8fbfbf"
    },
    "typeParameter": {
      "foreground": "#8fbfbf"
    },
    "enum": {
      "foreground": "#d8c089"
    },
    "enumMember": {
      "foreground": "#d8c089"
    },
    "function": {
      "foreground": "#82a0c0"
    },
    "method": {
      "foreground": "#82a0c0"
    },
    "property": {
      "foreground": "#e8e2cf"
    },
    "variable": {
      "foreground": "#e8e2cf"
    },
    "parameter": {
      "foreground": "#cfc6a8"
    },
    "string": {
      "foreground": "#d4a645"
    },
    "number": {
      "foreground": "#9fb87a"
    },
    "keyword": {
      "foreground": "#c08fcf"
    },
    "operator": {
      "foreground": "#bfa669"
    },
    "*.declaration": {
      "fontStyle": ""
    },
    "*.readonly": {
      "foreground": "#d8c089"
    },
    "*.deprecated": {
      "strikethrough": true,
      "foreground": "#6c6452"
    }
  }
}
